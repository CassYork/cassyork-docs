# Copy to deploy/.env.linode on the server and fill in secrets.
# docker compose --env-file .env.linode -f docker-compose.linode.yml up -d

# --- Postgres (shared by Temporal metadata + app DB cassyork) ---
POSTGRES_USER=temporal
POSTGRES_PASSWORD=change-me-strong

# DATABASE_URL is constructed in docker-compose.linode.yml from POSTGRES_USER + POSTGRES_PASSWORD.

# --- Temporal ---
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default

# --- Object storage (MinIO on same VM; use Linode Object Storage in production by swapping env) ---
OBJECT_STORAGE_SCHEME=s3
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=cassyork-documents
OBJECT_STORAGE_ACCESS_KEY_ID=minio
OBJECT_STORAGE_SECRET_ACCESS_KEY=change-me-minio-secret
OBJECT_STORAGE_USE_PATH_STYLE=true

# --- Optional telemetry ---
# OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317

# --- Admin UI ---
LISTEN_ADDR=:8095
# ADMIN_UI_LIST_LIMIT=200

# Optional: link from Settings page (use your VM IP or DNS)
# TEMPORAL_UI_URL=https://temporal.yourdomain.com
# WEBHOOK_API_PUBLIC_URL=http://YOUR_LINODE_IP:8095
